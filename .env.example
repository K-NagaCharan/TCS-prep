# Groq API Configuration for TCS NQT Verbal Practice Portal
# Copy this file to '.env.local' or '.env' and fill in your keys.

# Key A: For Paper Generation (uses temperature: 0.9 for content variety)
VITE_GROQ_KEY_A=gsk_your_generator_api_key_here
VITE_GROQ_MODEL_A=llama-3.3-70b-versatile

# Key B: For Response Evaluation (uses temperature: 0.2 for grading consistency)
VITE_GROQ_KEY_B=gsk_your_evaluator_api_key_here
VITE_GROQ_MODEL_B=llama-3.3-70b-versatile
